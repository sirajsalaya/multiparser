{
  "name": "multi-parser",
  "version": "1.0.0",
  "description": "Express-compatible multipart/form-data middleware that writes files into req.body key paths.",
  "keywords": [
    "multipart",
    "form-data",
    "express",
    "middleware",
    "upload",
    "busboy",
    "typescript"
  ],
  "author": "Siraj",
  "license": "ISC",
  "type": "commonjs",
  "sideEffects": false,
  "engines": {
    "node": ">=18.18.0"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "clean": "rimraf dist",
    "build": "rimraf dist && tsup",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "prepare": "husky",
    "test": "jest --runInBand",
    "test:ci": "jest --ci --runInBand --coverage",
    "test:watch": "jest --watch",
    "prepublishOnly": "npm run check && npm run pack:check",
    "pack:check": "npm pack --dry-run",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --ignore-path .gitignore --write \"**/*.+(js|ts|json|md|yml|yaml)\"",
    "commitlint": "commitlint --edit"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs,mts,cts}": [
      "eslint --fix --max-warnings=0"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "peerDependencies": {
    "express": "^4.21.0 || ^5.2.1"
  },
  "dependencies": {
    "busboy": "^1.6.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@types/busboy": "^1.5.4",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.14",
    "@types/node": "^25.6.0",
    "@types/supertest": "^6.0.3",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.2.1",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2"
  }
}
